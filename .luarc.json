{
  "Lua.runtime": {
    "version": "LuaJIT",
    "path": [
      "lua/?.lua",
      "lua/?/init.lua"
    ]
  },
  "Lua.diagnostics.globals": [
    "vim"
  ],
  "Lua.workspace.library": [
    "$VIMRUNTIME/lua",
    "$VIMRUNTIME/lua/vim",
    "$VIMRUNTIME/lua/vim/lsp",
    "${3rd}/luv/library",
    "${3rd}/busted/library"
  ],
  "Lua.workspace.checkThirdParty": false
}
